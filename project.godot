; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="CongaMechs"
run/main_scene="res://scenes/ui/StartScreen.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

RunManager="*res://src/RunManager.gd"
AudioManager="*res://src/AudioManager.gd"
SaveData="*res://src/SaveData.gd"
InputHints="*res://src/InputHints.gd"
InputBindings="*res://src/InputBindings.gd"

[display]

window/size/viewport_width=2880
window/size/viewport_height=1800
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/size/mode.editor=0

